{
  "name": "wispucci-ai-beta",
  "version": "0.1.0",
  "description": "Wispucci Ai beta desktop app.",
  "main": "./out/main/index.js",
  "author": "Wisp+Flow Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amoguse3/wispucci-ai-beta.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "web:start": "electron ./out/main/web-local.js",
    "web:local": "npm run build && npm run web:start",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.11",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "app.wispflow.wispucci-ai-beta",
    "productName": "Wispucci Ai beta",
    "copyright": "Copyright © 2026 Wisp+Flow Team",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "artifactName": "Wispucci-Ai-beta-${version}-Setup.${ext}",
      "sign": null,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wispucci Ai beta"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "amoguse3",
        "repo": "wispucci-ai-beta",
        "releaseType": "release"
      }
    ],
    "compression": "maximum"
  }
}
